# sensors2mqtt environment configuration
# Copy to /etc/sensors2mqtt/env and edit to match your setup.
#
# This file is sourced by systemd EnvironmentFile= directive.

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
POLL_INTERVAL=30

# IPMI collector only:
# BMC_HOST=your-bmc-host
# BMC_USER=admin
# BMC_PASS=password
